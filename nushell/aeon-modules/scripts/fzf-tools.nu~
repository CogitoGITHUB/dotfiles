def fzf-open [
    path?: string
] {
    let root = ($path | default ".")

    let result = (
        fd --type f . $root
        | str join "\n"
        | fzf
            --preview "bat --color=always --style=numbers {}"
            --preview-window "right:60%:wrap"
            --prompt "  File> "
            --header "o=bat  e=emacs  u=nvim"
            --bind "o:become(echo bat:{})"
            --bind "e:become(echo emacs:{})"
            --bind "u:become(echo nvim:{})"
        | str trim
    )

    if ($result | is-empty) { return }

    let parts = ($result | split row ":")
    let action = ($parts | first)
    let file   = ($parts | get 1)

    match $action {
        "bat"   => { bat --color=always $file }
        "emacs" => { ^emacs $file }
        "nvim"  => { ^nvim $file }
        _       => { print "No action taken." }
    }
}

def fzf-grep [
    query?: string
] {
    let q = ($query | default "")

    let result = (
        rg --color=always --line-number --no-heading --smart-case ""
        | fzf
            --ansi
            --query $q
            --delimiter ":"
            --preview "bat --color=always --style=numbers --highlight-line {2} {1}"
            --preview-window "right:60%:+{2}+3/3:wrap"
            --prompt "  Grep> "
            --header "o=bat  e=emacs  u=nvim"
            --bind "o:become(echo bat:{1}:{2})"
            --bind "e:become(echo emacs:{1}:{2})"
            --bind "u:become(echo nvim:{1}:{2})"
            --bind "change:reload:rg --color=always --line-number --no-heading --smart-case {q} || true"
        | str trim
    )

    if ($result | is-empty) { return }

    let parts = ($result | split row ":")
    let action = ($parts | first)
    let file   = ($parts | get 1)
    let line   = ($parts | get 2 | into int)

    match $action {
        "bat"   => { bat --color=always $file }
        "emacs" => { ^emacs $"+($line)" $file }
        "nvim"  => { ^nvim $"+($line)" $file }
        _       => { print "No action taken." }
    }
}

$env.config.keybindings ++= [
    {
        name: fzf_file_open
        modifier: CONTROL
        keycode: char_f
        mode: [emacs, vi_insert, vi_normal]
        event: { send: executehostcommand cmd: "fzf-open" }
    }
]