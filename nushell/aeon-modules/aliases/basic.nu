alias ll = lsd -all
alias e = emacs -nw
alias n = nvim

alias gg = cd ~/.config; git gg

alias gms = git submodule status
alias gmi = git submodule init
alias gmu = git submodule update
alias gmuf = git submodule update --init --recursive
alias gma = git submodule add

# Guix
alias gr = nu ~/.config/nushell/aeon-modules/scripts/guix/gr.nu
