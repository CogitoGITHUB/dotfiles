{
  // Storage location for memory database
  "storagePath": "~/.opencode-mem/data",
  
  // Enable web interface at http://127.0.0.1:4747
  "webServerEnabled": true,
  "webServerPort": 4747,
  
  // Auto-capture important information from conversations
  "autoCaptureEnabled": true,
  "autoCaptureLanguage": "auto",
  
  // Use OpenCode's built-in AI providers (no extra API key needed)
  "opencodeProvider": "anthropic",
  "opencodeModel": "claude-haiku-4-5-20251001",
  
  // Show notifications for memory events
  "showAutoCaptureToasts": true,
  "showUserProfileToasts": true,
  "showErrorToasts": true,
  
  // Memory limits - increased for more session context
  "maxMemories": 50,
  
  // User profile analysis more frequently
  "userProfileAnalysisInterval": 5,
  
  // Chat integration - inject more memories into context
  "chatMessage": {
    "enabled": true,
    "maxMemories": 5,
    "excludeCurrentSession": false
  },
  
  // Auto-compact memories
  "compaction": {
    "enabled": true,
    "memoryLimit": 10
  }
}
