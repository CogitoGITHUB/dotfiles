{
  "$schema": "https://opencode.ai/config.json",
  "command": {
    "guix-pull": {
      "agent": "build",
      "description": "Update Guix",
      "template": "Run `guix pull` to update Guix channels and package definitions."
    },
    "guix-reconfigure": {
      "agent": "build",
      "description": "Reconfigure Guix system",
      "template": "Run `sudo guix system reconfigure /home/aoeu/.config/guix/guixos.scm` to apply configuration changes."
    },
    "rollback": {
      "description": "Rollback Guix system",
      "template": "Run `sudo guix system roll-back` to revert to previous generation."
    },
    "show-generations": {
      "description": "List Guix generations",
      "template": "Run `guix system list-generations` to see available system generations."
    }
  },
  "formatter": {
    "latexindent": {
      "command": [
        "latexindent",
        "$FILE"
      ],
      "extensions": [
        ".tex"
      ]
    },
    "nixfmt": {
      "command": [
        "nixfmt",
        "$FILE"
      ],
      "extensions": [
        ".nix",
        ".scm"
      ]
    },
    "prettier": {
      "command": [
        "prettier",
        "--write",
        "$FILE"
      ],
      "environment": {},
      "extensions": [
        ".js",
        ".jsx",
        ".ts",
        ".tsx",
        ".css",
        ".html",
        ".json",
        ".yaml",
        ".yml",
        ".md"
      ]
    },
    "ruff": {
      "command": [
        "ruff",
        "format",
        "$FILE"
      ],
      "extensions": [
        ".py",
        ".pyi"
      ]
    }
  },
  "instructions": [
    "/home/aoeu/.config/opencode/INSTRUCTIONS.md"
  ],
  "mcp": {
    "context7": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "everything": {
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-everything"
      ],
      "enabled": true,
      "type": "local"
    },
    "filesystem": {
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/home/aoeu"
      ],
      "enabled": true,
      "type": "local"
    },
    "gh_grep": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "github": {
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "enabled": true,
      "type": "local"
    },
    "memory": {
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "enabled": true,
      "type": "local"
    },
    "playwright": {
      "command": [
        "npx",
        "-y",
        "@playwright/mcp"
      ],
      "enabled": true,
      "type": "local"
    },
    "slack": {
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-slack"
      ],
      "enabled": false,
      "type": "local"
    },
    "sqlite": {
      "command": [
        "npx",
        "-y",
        "mcp-sqlite-server"
      ],
      "enabled": true,
      "type": "local"
    }
  },
  "model": "ollama/qwen3.5",
  "permission": "allow",
  "plugin": [
    "opencode-zellij-tab-status",
    "opencode-zellij-namer",
    "zellij-pane-tracker",
    "./plugins/falcode.js",
    "opencode-mem"
  ],
  "provider": {
    "ollama": {
      "models": {
        "qwen3.5": {
          "_launch": true,
          "name": "qwen3.5"
        }
      },
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      }
    }
  }
}