   '(org-level-7 ((t (:foreground \"#000000\" :height 1.00))))
   '(org-level-8 ((t (:foreground \"#000000\" :height 1.00))))

   '(org-document-title ((t (:foreground \"#000000\" :weight bold :height 1.4))))
   '(org-link ((t (:foreground \"#000000\" :underline nil))))

