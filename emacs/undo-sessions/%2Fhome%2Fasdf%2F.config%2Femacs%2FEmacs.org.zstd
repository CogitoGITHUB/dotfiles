" . 7035823) ((marker . 7036099) . -173) ((marker . 7036034) . -173) ((marker . 7036706) . -173) ((marker . 7036707) . -173) 7035996 nil (7035999 . 7036002) (t 26919 28204 298812 47000) nil (7032025 . 7034999) nil ("(leaf modus-themes
  :load-path \"/home/asdf/.config/emacs/lib/modus-themes\"
  :init
  (setq modus-themes-bold-constructs t
        modus-themes-italic-constructs t
        modus-themes-org-blocks 'gray-background
        modus-themes-fringes 'intense)
  :config
  (load-theme 'modus-operandi :no-confirm)

  (defun shapeshift/monochrome-world ()
    \"Force Emacs into strict black-on-white.\"
    ;; canvas
    (set-face-attribute 'default nil
                        :foreground \"#000000\"
                        :background \"#ffffff\")

    ;; org headings big + bold + monochrome
    (set-face-attribute 'org-level-1 nil :foreground \"#000000\" :weight 'bold :height 1.80 :inherit nil)
    (set-face-attribute 'org-level-2 nil :foreground \"#000000\" :weight 'bold :height 1.60 :inherit nil)
    (set-face-attribute 'org-level-3 nil :foreground \"#000000\" :weight 'bold :height 1.40 :inherit nil)
    (set-face-attribute 'org-level-4 nil :foreground \"#000000\" :weight 'bold :height 1.25 :inherit nil)
    (set-face-attribute 'org-level-5 nil :foreground \"#000000\" :weight 'bold :height 1.10 :inherit nil)
    (set-face-attribute 'org-level-6 nil :foreground \"#000000\" :weight 'bold :height 1.05 :inherit nil)
    (set-face-attribute 'org-level-7 nil :foreground \"#000000\" :weight 'bold :height 1.05 :inherit nil)
    (set-face-attribute 'org-level-8 nil :foreground \"#000000\" :weight 'bold :height 1.05 :inherit nil)
    (set-face-attribute 'org-document-title nil :foreground \"#000000\" :weight 'bold :height 2.0 :inherit nil)

    ;; links stripped
    (set-face-attribute 'org-link nil :underline nil :inherit nil)

    ;; syntax, dired, superstar stay unchanged
    (dolist (face '(font-lock-comment-face
                    font-lock-string-face
                    font-lock-keyword-face
                    font-lock-function-name-face
                    font-lock-variable-name-face
                    font-lock-type-face
                    font-lock-constant-face))
      (set-face-attribute face nil :foreground \"#000000\"))

    (dolist (face '(dired-directory dired-symlink dired-broken-symlink
                    dired-flagged dired-mark dired-marked
                    dired-perm-write dired-special dired-warning))
      (set-face-attribute face nil :foreground \"#000000\")))

  (shapeshift/monochrome-world)

  (advice-add 'load-theme :after
              (lambda (&rest _)
                (shapeshift/monochrome-world))))
" . 7032025) ((marker . 7036099) . -2436) ((marker . 7032995) . -346) ((marker . 7034999) . -2437) ((marker . 7036034) . -2436) ((marker . 7036706) . -2436) ((marker . 7032025) . -2437) ((marker . 7036721) . -2437) ((marker . 7032025) . -2289) ((marker . 7032025) . -2437) (t 26919 28065 535668 115000) nil (7032025 . 7034462) nil ("  (leaf modus-themes
    :load-path \"/home/asdf/.config/emacs/lib/modus-themes\"
    :init
    (setq modus-themes-bold-constructs t
          modus-themes-italic-constructs t
          modus-themes-org-blocks 'gray-background
          modus-themes-fringes 'intense)
    :config
    ;; 1. Load the theme
    (load-theme 'modus-operandi :no-confirm)

    ;; 2. Define a function that *brutally* bleaches everything
    (defun shapeshift/monochrome-world ()
      \"Force Emacs into strict black-on-white.\"
      ;; canvas
      (set-face-attribute 'default nil
                          :foreground \"#000000\"
                          :background \"#ffffff\")


    ;; org headings — huge and bold
    (set-face-attribute 'org-level-1 nil
                        :foreground \"#000000\"
                        :weight 'bold
                        :height 1.80
                        :inherit nil)

    (set-face-attribute 'org-level-2 nil
                        :foreground \"#000000\"
                        :weight 'bold
                        :height 1.60
                        :inherit nil)

    (set-face-attribute 'org-level-3 nil
                        :foreground \"#000000\"
                        :weight 'bold
                        :height 1.40
                        :inherit nil)

    (set-face-attribute 'org-level-4 nil
                        :foreground \"#000000\"
                        :weight 'bold
                        :height 1.25
                        :inherit nil)

    (set-face-attribute 'org-level-5 nil
                        :foreground \"#000000\"
                        :weight 'bold
                        :height 1.10
                        :inherit nil)

    (set-face-attribute 'org-level-6 nil
                        :foreground \"#000000\"
                        :weight 'bold
                        :height 1.05
                        :inherit nil)

    (set-face-attribute 'org-level-7 nil
                        :foreground \"#000000\"
                        :weight 'bold
                        :height 1.05
                        :inherit nil)

    (set-face-attribute 'org-level-8 nil
                        :foreground \"#000000\"
                        :weight 'bold
                        :height 1.05
                        :inherit nil)

    ;; document title — monument stone
    (set-face-attribute 'org-document-title nil
                        :foreground \"#000000\"
                        :weight 'bold
                        :height 2.0
                        :inherit nil)


      
      ;; syntax
      (dolist (face '(font-lock-comment-face
                      font-lock-string-face
                      font-lock-keyword-face
                      font-lock-function-name-face
                      font-lock-variable-name-face
                      font-lock-type-face
                      font-lock-constant-face))
        (set-face-attribute face nil :foreground \"#000000\"))

      ;; dired
      (dolist (face '(dired-directory
                      dired-symlink
                      dired-broken-symlink
                      dired-flagged
                      dired-mark
                      dired-marked
                      dired-perm-write
                      dired-special
                      dired-warning))
        (set-face-attribute face nil :foreground \"#000000\"))

      ;; org-superstar / bullets if needed later
      (dolist (face '(org-superstar-header-bullet
                      org-superstar-item
                      org-superstar-leading))
        (when (facep face)
          (set-face-attribute face nil :foreground \"#000000\"))))

    ;; 3. Apply immediately
    (shapeshift/monochrome-world)

    ;; 4. Re-apply after ANY future theme load
    (advice-add 'load-theme :after
                (lambda (&rest _)
                  (shapeshift/monochrome-world))))
