;; -*- mode: emacs-lisp; coding: utf-8-unix -*-
;; Minibuffer history file, automatically generated by ‘savehist’.

(setq savehist-minibuffer-history-variables '(read-number-history read-char-history file-name-history extended-command-history))
(setq read-char-history '("yes" "all"))
(setq file-name-history '("~/"))
(setq extended-command-history '("restart-emacs" "eval-buffer"))
