;; ════════════════════════════════════════════════════════════
;; § DENOTE — FILE NAMING & ORGANIZATION
;; ════════════════════════════════════════════════════════════
;; Denote provides a structured file-naming scheme:
;; YYYY-MM-DD--HH-MM--title_keywords--signature.live
;;
;; Components:
;; - Date/time: Unique identifier and chronological ordering
;; - Title: Human-readable name (slugified)
;; - Keywords: Tags for categorization (prefixed with _)
;; - Signature: Optional identifier (prefixed with --)
;; - Extension: .live (custom extension for source files)
;; 
;; Note: Uses -- instead of == for LaTeX filename compatibility

(setq denote-directory (expand-file-name shapeshift/denote-silos-dir))
(setq denote-file-type 'org)
(setq denote-date-format "%Y-%m-%d--%H-%M")
(setq denote-prompts '(title keywords subdirectory signature))
(setq org-startup-with-inline-images nil)
(setq org-startup-folded 'showall)
#+end_src

