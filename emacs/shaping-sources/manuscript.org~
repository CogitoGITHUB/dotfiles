** Note Creation Command :config:
#+begin_src emacs-lisp
;; ════════════════════════════════════════════════════════════
;; § NOTE CREATION — DIRECT COMMAND
;; ════════════════════════════════════════════════════════════
;; Direct command to create new .live files without org-capture complexity.

(defun shapeshift/create-new-note ()
  "Create a new denote note with .live extension."
  (interactive)
  ;; Store current buffer for bidirectional linking
  (setq shapeshift/source-buffer-for-linking (current-buffer))
  ;; Create the file and open it
  (let ((new-file (shapeshift/denote-capture-create-file)))
    (find-file new-file)
    (goto-char (point-max))))
