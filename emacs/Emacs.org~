* Live-Shaping: Tangle & Reload

#+begin_src emacs-lisp
(defun live-shaping/tangle-and-reload ()
  "Tangle Emacs.org and reload init.el."
  (interactive)
  (let ((org-file "~/.config/emacs/Emacs.org")
        (init-file "~/.config/emacs/init.el"))
    ;; Tangle
    (org-babel-tangle-file org-file)
    ;; Reload init
    (load-file init-file)
    (message "⚡ Live-Shaping: Emacs reloaded.")))

;; Bind to a key:
;; Press: C-c r  → tangle Emacs.org + reload init.el
(global-set-key (kbd "C-c r") #'live-shaping/tangle-and-reload)
#+end_src

