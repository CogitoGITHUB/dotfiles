;; denote.el --- Shapeless Denote module -*- lexical-binding: t; -*-

;;; Commentary:
;; Local Denote from Package-Sources, fully integrated into Shapeless.

;;; Code:

(use-package denote
  :load-path (lambda ()
               (list (expand-file-name
                      "Shapeless-Hyperlinks/Package-Sources/denote"
                      user-emacs-directory)))
  :init
  ;; Base directory for all Shapeless notes
  (setq denote-directory (expand-file-name "~/Shapeless-Links"))

  ;; Your preferred file type
  (setq denote-file-type 'org)

  ;; Keywords you’ll be using for categorizing Emacs manuals
  (setq denote-known-keywords '("emacs" "manual" "lisp" "editing" "ui" "core"))

  ;; Automatically use nice titles
  (setq denote-sort-keywords t)

  :config
(provide 'denote))
;;; denote.el ends here
