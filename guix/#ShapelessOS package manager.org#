** With Docker/Containers

Generate Dockerfiles from package definitions:

#+BEGIN_SRC emacs-lisp :tangle no
(defun shapeless-generate-dockerfile (package-name)
  "Generate Dockerfile for PACKAGE-NAME."
  (interactive "sPackage name: ")
  (let* ((package (plist-get shapeless-packages (intern package-name)))
         (output-file (format "Dockerfile.%s" package-name)))
    (with-temp-file output-file
      (insert "FROM shapelessos/base:latest\n\n")
      (insert (format "# Install %s\n" package-name))
      (insert (format "RUN guix install %s\n\n" package-name))
      (insert (format "# Stow to /usr\n"))
      (insert (format "RUN stow -d /gnu/store -t /usr %s\n" package-name))
      (insert (format "\nCMD [\"%s\"]\n" package-name)))
    (message "Generated %s" output-file)))
#+END_SRC

