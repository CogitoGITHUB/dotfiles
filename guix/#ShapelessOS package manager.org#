(defvar shapeless-packages '()
  "Registry of all ShapelessOS packages.
Plist where keys are package symbols, values are package metadata plists.")

(defvar shapeless-package-fields
  '("name" "version" "source" "build-system" "arguments" 
    "inputs" "native-inputs" "propagated-inputs"
    "home-page" "synopsis" "description" "license"
    "stow-target" "git-repo" "git-branch" "update-frequency")
  "Standard package fields recognized by shapeless package manager.")

(defcustom shapeless-packages-directory
  (expand-file-name "packages" user-emacs-directory)
  "Directory containing org-mode package definitions."
  :type 'string
  :group 'shapeless)

(defcustom shapeless-output-directory
  (expand-file-name "guix-packages" user-emacs-directory)
  "Directory for generated Guix package definitions."
  :type 'string
  :group 'shapeless)

(defcustom shapeless-cache-directory
  (expand-file-name "shapeless-cache" user-emacs-directory)
  "Directory for package metadata cache."
  :type 'string
  :group 'shapeless)

(defcustom shapeless-maak-executable "maak"
  "Path to MAAK executable."
  :type 'string
