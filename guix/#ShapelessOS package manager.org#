;; ============================================================================
;; Utility Functions
;; ============================================================================

(defun shapeless-indent (string n)
  "Indent STRING by N spaces."
  (let ((indentation (make-string n ?\s)))
    (replace-regexp-in-string "^" indentation string)))

(defun shapeless-plist-keys (plist)
  "Return keys of PLIST."
  (let ((keys '()))
    (while plist
      (push (car plist) keys)
      (setq plist (cddr plist)))
    (nreverse keys)))

(defun shapeless-safe-read (string file &optional line)
  "Safely read STRING as Scheme/Lisp."
  (condition-case err
      (read string)
    (error
     (display-warning
      'shapeless
      (format "Failed to read %s:%s - %s" file (or line "?") 
              (error-message-string err))
      :error)
     nil)))

;; ============================================================================
;; Org Property Extraction
;; ============================================================================

(defun shapeless-find-property (property)
  "Find PROPERTY in current or ancestor org element."
  (save-excursion
    (condition-case nil
        (progn
          (while (not (org-element-property property (org-element-context)))
            (org-up-element))
          (org-element-property property (org-element-context)))
      (error nil))))

(defun shapeless-find-tags ()
  "Find tags in current or ancestor org element."
  (save-excursion
    (condition-case nil
        (progn
          (while (not (org-element-property :tags 
                        (org-element-lineage (org-element-context) '(headline) t)))
            (org-up-element))
          (org-element-property :tags 
            (org-element-lineage (org-element-context) '(headline) t)))
      (error nil))))

(defun shapeless-find-tag ()
  "Find a package field tag in current context."
  (let* ((fields shapeless-package-fields)
         (tag (car (seq-filter (lambda (tag) (member tag fields)) 
                               (shapeless-find-tags)))))
    (when tag
      (replace-regexp-in-string "_" "-" tag))))

(defun shapeless-find-package ()
  "Find package name in current context."
  (or (shapeless-find-property :PACKAGE)
      (shapeless-find-property :NAME)))

(defun shapeless-find-git-repo ()
  "Find git repository URL."
  (shapeless-find-property :GIT_REPO))

(defun shapeless-find-git-branch ()
  "Find git branch to track."
  (or (shapeless-find-property :GIT_BRANCH) "main"))

(defun shapeless-find-update-frequency ()
  "Find update check frequency (hourly, daily, weekly)."
  (or (shapeless-find-property :UPDATE_FREQUENCY) "hourly"))

(defun shapeless-find-stow-target ()
  "Find stow target directory."
  (or (shapeless-find-property :STOW_TARGET) "/usr/local"))

(defun shapeless-get-package-field ()
  "Return (PACKAGE-NAME FIELD) for current context."
  (when-let* ((package (shapeless-find-package))
              (field (or (shapeless-find-property :FIELD)
                        (shapeless-find-tag))))
    (list package field)))

;; ============================================================================
;; Package Registry Management
;; ============================================================================

(defun shapeless-put-package-parameter (package-name parameter value)
  "Store PARAMETER with VALUE for PACKAGE-NAME."
  (setq shapeless-packages
        (plist-put
         shapeless-packages
         (intern package-name)
         (plist-put (plist-get shapeless-packages (intern package-name))
                    parameter
                    value))))

(defun shapeless-add-package-field (package body element file)
  "Add field BODY to PACKAGE configuration."
  (let* ((begin (org-element-property :begin element))
         (line (line-number-at-pos begin))
         (package-name (car package))
         (package-field (intern (concat ":" (car (cdr package)))))
         (previous-body (plist-get (plist-get shapeless-packages 
                                              (intern package-name)) 
                                   package-field))
         (value (append previous-body `((:body ,body :line ,line :file ,file)))))
    (shapeless-put-package-parameter package-name package-field value)))

;; ============================================================================
;; Git Operations
;; ============================================================================

(defun shapeless-git-latest-commit (repo branch)
  "Get latest commit hash from REPO on BRANCH."
  (let ((output (shell-command-to-string
                 (format "git ls-remote %s %s 2>/dev/null" repo branch))))
    (when (string-match "^\\([a-f0-9]+\\)" output)
      (match-string 1 output))))

(defun shapeless-git-compute-hash (repo commit)
  "Compute source hash for REPO at COMMIT."
  (let* ((temp-dir (make-temp-file "shapeless-git-" t))
         (clone-cmd (format "git clone --depth 1 %s %s 2>/dev/null" repo temp-dir))
         (checkout-cmd (format "cd %s && git checkout %s 2>/dev/null" temp-dir commit))
         (tar-file (concat temp-dir ".tar.gz"))
         (tar-cmd (format "tar -czf %s --sort=name --owner=0 --group=0 --mtime='1970-01-01' -C %s ." 
                         tar-file temp-dir))
         (hash-cmd (format "sha256sum %s | cut -d' ' -f1" tar-file)))
    
    (unwind-protect
        (when (and (= 0 (shell-command clone-cmd))
                   (= 0 (shell-command checkout-cmd))
                   (= 0 (shell-command tar-cmd)))
          (string-trim (shell-command-to-string hash-cmd)))
      ;; Cleanup
      (when (file-exists-p temp-dir)
        (delete-directory temp-dir t))
      (when (file-exists-p tar-file)
        (delete-file tar-file)))))

(defun shapeless-update-package-hash (package-name)
  "Update hash for PACKAGE-NAME by fetching latest git commit."
  (let* ((package (plist-get shapeless-packages (intern package-name)))
         (git-repo (plist-get package :git-repo))
         (git-branch (plist-get package :git-branch)))
    
    (when (and git-repo git-branch)
      (message "Shapeless: Checking %s for updates..." package-name)
      (let* ((latest-commit (shapeless-git-latest-commit git-repo git-branch))
             (current-commit (plist-get package :git-commit)))
        
        (if (and latest-commit (not (equal latest-commit current-commit)))
            (progn
              (message "Shapeless: Computing hash for %s..." package-name)
              (let ((hash (shapeless-git-compute-hash git-repo latest-commit)))
                (when hash
                  (shapeless-put-package-parameter package-name :git-commit latest-commit)
                  (shapeless-put-package-parameter package-name :computed-hash hash)
                  (shapeless-put-package-parameter package-name :last-updated 
                                                  (format-time-string "%Y-%m-%dT%H:%M:%S"))
                  (message "Shapeless: Updated %s to %s (hash: %s)" 
                          package-name 
                          (substring latest-commit 0 8)
                          (substring hash 0 16))
                  t)))
          (message "Shapeless: %s is up to date" package-name)
          nil)))))

;; ============================================================================
;; Guix Package Generation
;; ============================================================================

(defun shapeless-build-guix-source (package)
  "Build Guix source definition for PACKAGE."
  (let* ((git-repo (plist-get package :git-repo))
         (git-commit (plist-get package :git-commit))
         (hash (plist-get package :computed-hash)))
    (when (and git-repo git-commit hash)
      (format "(origin
  (method git-fetch)
  (uri (git-reference
        (url \"%s\")
        (commit \"%s\")))
  (file-name (git-file-name name version))
  (sha256
   (base32 \"%s\")))"
              git-repo git-commit hash))))

(defun shapeless-build-guix-package (package-name package file)
  "Build complete Guix package definition for PACKAGE-NAME."
  (let* ((name (or (plist-get (car (plist-get package :name)) :body)
                  package-name))
         (version (or (plist-get (car (plist-get package :version)) :body)
                     "git"))
         (source (or (plist-get (car (plist-get package :source)) :body)
                    (shapeless-build-guix-source package)))
         (build-system (plist-get (car (plist-get package :build-system)) :body))
         (arguments (plist-get (car (plist-get package :arguments)) :body))
         (inputs (plist-get (car (plist-get package :inputs)) :body))
         (native-inputs (plist-get (car (plist-get package :native-inputs)) :body))
         (propagated-inputs (plist-get (car (plist-get package :propagated-inputs)) :body))
         (home-page (plist-get (car (plist-get package :home-page)) :body))
         (synopsis (plist-get (car (plist-get package :synopsis)) :body))
         (description (plist-get (car (plist-get package :description)) :body))
         (license (plist-get (car (plist-get package :license)) :body)))
    
    (concat
     (format "(define-public %s\n" package-name)
     "  (package\n"
     (format "    (name \"%s\")\n" name)
     (format "    (version \"%s\")\n" version)
     (when source
       (format "    (source\n%s)\n" (shapeless-indent source 5)))
     (when build-system
       (format "    (build-system %s)\n" build-system))
     (when arguments
       (format "    (arguments\n%s)\n" (shapeless-indent arguments 5)))
     (when inputs
       (format "    (inputs\n%s)\n" (shapeless-indent inputs 5)))
     (when native-inputs
       (format "    (native-inputs\n%s)\n" (shapeless-indent native-inputs 5)))
     (when propagated-inputs
       (format "    (propagated-inputs\n%s)\n" (shapeless-indent propagated-inputs 5)))
     (when home-page
       (format "    (home-page \"%s\")\n" home-page))
     (when synopsis
       (format "    (synopsis \"%s\")\n" synopsis))
     (when description
       (format "    (description\n%s)\n" (shapeless-indent description 5)))
     (when license
       (format "    (license %s)\n" license))
     "  ))\n\n")))

;; ============================================================================
;; Org File Processing
;; ============================================================================

(defun shapeless-process-org-file (file)
  "Extract package definitions from org FILE."
  (with-temp-buffer
    (insert-file-contents file)
    (org-mode)
    
    ;; Extract properties from headlines
    (org-map-entries
     (lambda ()
       (when-let* ((package-name (shapeless-find-package)))
         (let ((line (line-number-at-pos)))
           ;; Store metadata
           (shapeless-put-package-parameter package-name :package line)
           
           (when-let ((git-repo (shapeless-find-git-repo)))
             (shapeless-put-package-parameter package-name :git-repo git-repo))
           
           (when-let ((git-branch (shapeless-find-git-branch)))
             (shapeless-put-package-parameter package-name :git-branch git-branch))
           
           (when-let ((update-freq (shapeless-find-update-frequency)))
             (shapeless-put-package-parameter package-name :update-frequency update-freq))
           
           (when-let ((stow-target (shapeless-find-stow-target)))
             (shapeless-put-package-parameter package-name :stow-target stow-target))))))
    
    ;; Process source blocks
    (org-babel-map-src-blocks nil
      (let ((body (org-element-property :value (org-element-context)))
            (language (org-element-property :language (org-element-context))))
        (when (or (string= language "scheme") (string= language "guile"))
          (when-let ((package (shapeless-get-package-field)))
            (shapeless-add-package-field package body 
                                        (org-element-context) file)))))))

;; ============================================================================
;; Compilation and Output
;; ============================================================================

(defun shapeless-compile-packages ()
  "Process all org files and generate Guix packages."
  (interactive)
  (setq shapeless-packages nil)
  
  ;; Ensure directories exist
  (make-directory shapeless-packages-directory t)
  (make-directory shapeless-output-directory t)
  (make-directory shapeless-cache-directory t)
  
  ;; Process all org files
  (let ((org-files (directory-files-recursively 
                    shapeless-packages-directory "^[^#].*\\.org$")))
    (dolist (file org-files)
      (message "Shapeless: Processing %s..." (file-name-nondirectory file))
      (shapeless-process-org-file file)))
  
  ;; Generate Guix package files
  (let ((package-names (shapeless-plist-keys shapeless-packages)))
    (dolist (pkg-name package-names)
      (let* ((package (plist-get shapeless-packages pkg-name))
             (output-file (expand-file-name 
                          (format "%s.scm" pkg-name)
                          shapeless-output-directory))
             (guix-code (shapeless-build-guix-package 
                        (symbol-name pkg-name) package nil)))
        
        (when guix-code
          (with-temp-file output-file
            (insert ";;; Generated by ShapelessOS Package Manager\n")
            (insert ";;; Do not edit manually\n\n")
            (insert "(define-module (shapeless packages)\n")
            (insert "  #:use-module (guix packages)\n")
            (insert "  #:use-module (guix git-download)\n")
            (insert "  #:use-module (guix build-system gnu)\n")
            (insert "  #:use-module ((guix licenses) #:prefix license:))\n\n")
            (insert guix-code))
          (message "Shapeless: Generated %s" output-file)))))
  
  (message "Shapeless: Compilation complete. %d packages processed." 
           (length (shapeless-plist-keys shapeless-packages))))

;; ============================================================================
;; Update System
;; ============================================================================

(defun shapeless-update-all-packages ()
  "Check all packages for updates and recompute hashes."
  (interactive)
  (let ((package-names (shapeless-plist-keys shapeless-packages))
        (updated 0))
    (dolist (pkg-name package-names)
      (when (shapeless-update-package-hash (symbol-name pkg-name))
        (setq updated (1+ updated))))
    (when (> updated 0)
      (shapeless-compile-packages)
      (message "Shapeless: Updated %d package(s)" updated))
    (when (= updated 0)
      (message "Shapeless: All packages up to date"))))

(defun shapeless-update-package-at-point ()
  "Update package at current cursor position."
  (interactive)
  (if-let ((pkg-name (shapeless-find-package)))
      (progn
        (shapeless-update-package-hash pkg-name)
        (shapeless-compile-packages))
    (message "Shapeless: No package found at point")))

;; ============================================================================
;; Preview and Inspection
;; ============================================================================

(defun shapeless-preview-package ()
  "Preview generated Guix code for package at point."
  (interactive)
  (if-let* ((pkg-name (shapeless-find-package))
            (package (plist-get shapeless-packages (intern pkg-name)))
            (buffer (get-buffer-create "*shapeless-preview*")))
      (progn
        (with-current-buffer buffer
          (erase-buffer)
          (scheme-mode)
          (insert (shapeless-build-guix-package pkg-name package nil))
          (goto-char (point-min)))
        (display-buffer buffer))
    (message "Shapeless: No package found at point")))

(defun shapeless-show-package-info ()
  "Show metadata for package at point."
  (interactive)
  (if-let* ((pkg-name (shapeless-find-package))
            (package (plist-get shapeless-packages (intern pkg-name))))
      (message "Shapeless Package: %s
Git: %s @ %s
Commit: %s
Hash: %s
Last Updated: %s
Stow Target: %s"
               pkg-name
               (plist-get package :git-repo)
               (plist-get package :git-branch)
               (or (plist-get package :git-commit) "not fetched")
               (or (plist-get package :computed-hash) "not computed")
               (or (plist-get package :last-updated) "never")
               (or (plist-get package :stow-target) "/usr/local"))
    (message "Shapeless: No package found at point")))

;; ============================================================================
;; Build Integration
;; ============================================================================

(defun shapeless-build-package ()
  "Build package at point using Guix."
  (interactive)
  (if-let* ((pkg-name (shapeless-find-package))
            (output-file (expand-file-name 
                         (format "%s.scm" pkg-name)
                         shapeless-output-directory)))
      (progn
        (shapeless-compile-packages)
        (compile (format "guix build -f %s %s" output-file pkg-name)))
    (message "Shapeless: No package found at point")))

(defun shapeless-install-package ()
  "Install package at point."
  (interactive)
  (if-let ((pkg-name (shapeless-find-package)))
      (progn
        (shapeless-compile-packages)
        (compile (format "guix install %s" pkg-name)))
    (message "Shapeless: No package found at point")))

;; ============================================================================
;; Auto-update System
;; ============================================================================

(defvar shapeless-update-timer nil
  "Timer for automatic package updates.")

(defun shapeless-start-auto-update ()
  "Start automatic hourly update checks."
  (interactive)
  (when shapeless-update-timer
    (cancel-timer shapeless-update-timer))
  (setq shapeless-update-timer
        (run-at-time "1 hour" 3600 #'shapeless-update-all-packages))
  (message "Shapeless: Auto-update started (hourly)"))

(defun shapeless-stop-auto-update ()
  "Stop automatic updates."
  (interactive)
  (when shapeless-update-timer
    (cancel-timer shapeless-update-timer)
    (setq shapeless-update-timer nil)
    (message "Shapeless: Auto-update stopped")))

;; ============================================================================
;; Minor Mode
;; ============================================================================

(defvar shapeless-mode-map
  (let ((map (make-sparse-keymap)))
    (define-key map (kbd "C-c s c") #'shapeless-compile-packages)
    (define-key map (kbd "C-c s u") #'shapeless-update-package-at-point)
    (define-key map (kbd "C-c s U") #'shapeless-update-all-packages)
    (define-key map (kbd "C-c s p") #'shapeless-preview-package)
    (define-key map (kbd "C-c s i") #'shapeless-show-package-info)
    (define-key map (kbd "C-c s b") #'shapeless-build-package)
    (define-key map (kbd "C-c s I") #'shapeless-install-package)
    map)
  "Keymap for shapeless-mode.")

(define-minor-mode shapeless-mode
  "Minor mode for ShapelessOS package management."
  :lighter " Shapeless"
  :keymap shapeless-mode-map)

;; ============================================================================
;; Initialization
;; ============================================================================

(defun shapeless-init ()
  "Initialize ShapelessOS package manager."
  (make-directory shapeless-packages-directory t)
  (make-directory shapeless-output-directory t)
  (make-directory shapeless-cache-directory t)
  
  ;; Enable shapeless-mode in package org files
  (add-hook 'org-mode-hook
            (lambda ()
              (when (and buffer-file-name
                         (file-in-directory-p buffer-file-name 
                                            shapeless-packages-directory))
                (shapeless-mode 1))))
  
  ;; Auto-compile on save
  (add-hook 'after-save-hook
            (lambda ()
              (when (and buffer-file-name
                         (file-in-directory-p buffer-file-name 
                                            shapeless-packages-directory))
                (shapeless-compile-packages))))
  
  (message "ShapelessOS Package Manager initialized"))

(provide 'shapeless-package-manager)
